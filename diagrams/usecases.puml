@startuml
' Use Case Diagram для текущей реализации сайта

left to right direction
skinparam packageStyle rectangle

actor "Пользователь" as User
actor "Источник предложений\n(banks.json)" as BanksData <<external>>

rectangle "Кредитный навигатор\n(текущая версия)" {

  ' Авторизация (index.html)
  usecase "Ввести номер телефона" as UC_EnterPhone
  usecase "Получить mock-SMS код" as UC_GetCode
  usecase "Ввести 6-значный код" as UC_EnterOtp
  usecase "Повторно отправить код\nпосле таймера 60 сек" as UC_Resend
  usecase "Сменить номер телефона" as UC_ChangePhone

  ' Список банков (banklist.html)
  usecase "Загрузить список банков" as UC_LoadBanks
  usecase "Просмотреть предложения банков" as UC_ViewBanks
  usecase "Выбрать предложение банка" as UC_SelectBank
  usecase "Перейти в профиль" as UC_OpenProfile
  usecase "Выйти на экран входа" as UC_Logout

  ' Анкета (application-form.html)
  usecase "Заполнить анкету" as UC_FillForm
  usecase "Проверить валидность полей" as UC_ValidateForm
  usecase "Очистить форму" as UC_ResetForm
  usecase "Отправить анкету" as UC_SubmitForm
  usecase "Вернуться к списку банков" as UC_BackToBanks

  ' Профиль (result.html)
  usecase "Просмотреть профиль и заявки" as UC_ViewProfile
  usecase "Показать этапы обработки заявки" as UC_ShowSteps
  usecase "Показать итог заявки:\nодобрена или отказана (mock)" as UC_ShowResult
}

' Связи пользователя
User --> UC_EnterPhone
User --> UC_EnterOtp
User --> UC_Resend
User --> UC_ChangePhone

User --> UC_ViewBanks
User --> UC_SelectBank
User --> UC_OpenProfile
User --> UC_Logout

User --> UC_FillForm
User --> UC_ResetForm
User --> UC_SubmitForm
User --> UC_BackToBanks

User --> UC_ViewProfile

' Внешний источник данных
BanksData --> UC_LoadBanks : JSON данные

' include / extend
UC_GetCode ..> UC_EnterPhone : <<include>>
UC_EnterOtp ..> UC_GetCode : <<include>>
UC_Resend ..> UC_GetCode : <<extend>>

UC_ViewBanks ..> UC_LoadBanks : <<include>>
UC_SelectBank ..> UC_ViewBanks : <<extend>>

UC_FillForm ..> UC_ValidateForm : <<include>>
UC_SubmitForm ..> UC_ValidateForm : <<include>>

UC_ViewProfile ..> UC_ShowSteps : <<include>>
UC_ViewProfile ..> UC_ShowResult : <<include>>

title Use Case Diagram — Кредитный навигатор (текущая версия)
@enduml